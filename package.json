{
	"name": "cometline",
	"private": true,
	"version": "0.1.0",
	"packageManager": "pnpm@11.3.0",
	"type": "module",
	"main": "electron/main.cjs",
	"scripts": {
		"dev": "concurrently \"pnpm run dev:vite\" \"pnpm run dev:electron\"",
		"dev:vite": "vite dev",
		"dev:electron": "wait-on http://127.0.0.1:5173 && electron .",
		"build:sidecar": "mkdir -p ../cometmind/dist && cd ../cometmind && go build -o dist/cometmind .",
		"generate:icons": "swift scripts/generate-project-icons.swift",
		"build": "vite build",
		"build:electron": "pnpm run build:sidecar && pnpm run build && electron-builder",
		"build:mac": "pnpm run build:sidecar && pnpm run build && electron-builder --mac --publish never",
		"release:mac": "pnpm run build:sidecar && pnpm run build && electron-builder --mac --publish always",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"devDependencies": {
		"@eslint/js": "^9.18.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.65.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.3",
		"autoprefixer": "^10.5.0",
		"concurrently": "^10.0.3",
		"electron": "^42.4.0",
		"electron-builder": "^26.15.3",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.1",
		"globals": "^15.14.0",
		"jsdom": "^29.1.1",
		"postcss": "^8.5.15",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"svelte-eslint-parser": "^0.43.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.20.0",
		"vite": "^8.0.16",
		"vitest": "^3.0.0",
		"wait-on": "^9.0.10"
	},
	"dependencies": {
		"@lucide/svelte": "^1.18.0",
		"dompurify": "^3.4.10",
		"electron-updater": "^6.8.9",
		"katex": "^0.17.0",
		"marked": "^18.0.5",
		"remend": "^1.3.0",
		"shiki": "^4.2.0"
	},
	"build": {
		"appId": "com.cometline.app",
		"productName": "Cometline",
		"directories": {
			"buildResources": "buildResources"
		},
		"mac": {
			"icon": "buildResources/icon.icns",
			"category": "public.app-category.developer-tools",
			"hardenedRuntime": true,
			"gatekeeperAssess": false,
			"entitlements": "buildResources/entitlements.mac.plist",
			"entitlementsInherit": "buildResources/entitlements.mac.plist",
			"notarize": true,
			"target": [
				"dmg",
				"zip"
			]
		},
		"publish": [
			{
				"provider": "github"
			}
		],
		"files": [
			"build/**/*",
			"electron/**/*",
			"package.json"
		],
		"extraResources": [
			{
				"from": "../cometmind/dist/cometmind",
				"to": "cometmind"
			},
			{
				"from": "SOUL.md",
				"to": "SOUL.md"
			},
			{
				"from": "buildResources/icon.png",
				"to": "icon.png"
			},
			{
				"from": "buildResources/trayIcon.png",
				"to": "trayIcon.png"
			},
			{
				"from": "buildResources/trayIcon@2x.png",
				"to": "trayIcon@2x.png"
			},
			{
				"from": "buildResources/trayTemplate.png",
				"to": "trayTemplate.png"
			}
		]
	}
}
